# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=datanalyst
DB_PASSWORD=secure_password_123
DB_NAME=warehouse

# Superset
SUPERSET_SECRET_KEY=$(openssl rand -hex 16)
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin123

# API
API_KEY=your-api-key-here
API_BASE_URL=https://api.example.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/workspace/logs/etl.log

# Environment
ENVIRONMENT=development